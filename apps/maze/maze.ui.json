{
  "type": "column",
  "padding": 16,
  "spacing": 10,
  "children": [
    { "type": "text", "value": "Maze", "style": "headline" },
    { "type": "text", "style": "caption",
      "value": "First-person crawler. Phone is the D-pad, e-ink is the view. Find the exit in the fewest steps." },

    { "type": "row", "spacing": 8, "align": "center", "children": [
      { "type": "button", "label": "←", "style": "secondary",
        "action": { "type": "push", "payload": { "action": "turn_left" } } },
      { "type": "column", "spacing": 8, "children": [
        { "type": "button", "label": "↑", "style": "primary",
          "action": { "type": "push", "payload": { "action": "forward" } } },
        { "type": "button", "label": "↓", "style": "secondary",
          "action": { "type": "push", "payload": { "action": "back" } } }
      ] },
      { "type": "button", "label": "→", "style": "secondary",
        "action": { "type": "push", "payload": { "action": "turn_right" } } }
    ] },

    { "type": "divider" },

    { "type": "button", "label": "New random maze", "style": "secondary",
      "action": { "type": "push", "payload": { "action": "new_random" } } },
    { "type": "button", "label": "Today's daily maze", "style": "secondary",
      "action": { "type": "push", "payload": { "action": "new_daily" } } },

    { "type": "divider" },

    { "type": "state_text", "binding": "mode",
      "format": "Mode: {}", "style": "caption" },
    { "type": "state_text", "binding": "moves",
      "format": "Steps: {}", "style": "caption" },
    { "type": "state_text", "binding": "facing",
      "format": "Facing: {}", "style": "caption" },
    { "type": "state_text", "binding": "optimal",
      "format": "Optimum: {}", "style": "caption" },
    { "type": "state_text", "binding": "best",
      "format": "Best: {}", "style": "caption" },
    { "type": "state_text", "binding": "seen",
      "format": "Explored: {}", "style": "caption" },
    { "type": "state_text", "binding": "wins",
      "format": "Mazes solved: {}", "style": "caption" }
  ]
}
