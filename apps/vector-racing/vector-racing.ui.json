{
  "type": "column",
  "padding": 16,
  "spacing": 10,
  "children": [
    { "type": "text", "value": "Vector Racing", "style": "headline" },
    { "type": "text", "style": "caption",
      "value": "Pen-and-paper Racetrack. Nudge your velocity by ±1; momentum carries you, so brake before the corners or clip the wall." },

    { "type": "when",
      "if": { "==": [ { "var": "state.status" }, "racing" ] },
      "then": [
        { "type": "text", "style": "caption",
          "value": "Each tap adds to your velocity. Centre = coast (no change)." },

        { "type": "row", "spacing": 8, "align": "center", "children": [
          { "type": "button", "label": "↖", "style": "secondary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": -1, "dy": -1 } } },
          { "type": "button", "label": "↑", "style": "secondary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": 0, "dy": -1 } } },
          { "type": "button", "label": "↗", "style": "secondary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": 1, "dy": -1 } } }
        ] },
        { "type": "row", "spacing": 8, "align": "center", "children": [
          { "type": "button", "label": "←", "style": "secondary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": -1, "dy": 0 } } },
          { "type": "button", "label": "coast", "style": "primary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": 0, "dy": 0 } } },
          { "type": "button", "label": "→", "style": "secondary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": 1, "dy": 0 } } }
        ] },
        { "type": "row", "spacing": 8, "align": "center", "children": [
          { "type": "button", "label": "↙", "style": "secondary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": -1, "dy": 1 } } },
          { "type": "button", "label": "↓", "style": "secondary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": 0, "dy": 1 } } },
          { "type": "button", "label": "↘", "style": "secondary",
            "action": { "type": "push", "payload": { "action": "accel", "dx": 1, "dy": 1 } } }
        ] },

        { "type": "divider" },

        { "type": "button", "label": "Abandon race", "style": "secondary",
          "action": { "type": "push", "payload": { "action": "abandon" } } }
      ],
      "else": [
        { "type": "select", "local": "mode", "label": "Mode",
          "default": "daily",
          "options": [
            { "value": "daily",  "label": "Daily"  },
            { "value": "random", "label": "Random" }
          ] },
        { "type": "select", "local": "crash", "label": "Crash rule",
          "default": "safe",
          "options": [
            { "value": "safe",     "label": "Safe — stop on a crash" },
            { "value": "hardcore", "label": "Hardcore — back to the line" }
          ] },
        { "type": "select", "local": "laps", "label": "Laps",
          "default": "2",
          "options": [
            { "value": "1", "label": "1" },
            { "value": "2", "label": "2" },
            { "value": "3", "label": "3" }
          ] },

        { "type": "button", "label": "Start race", "style": "primary",
          "action": { "type": "push",
            "payload": { "action": "start",
                         "mode":  "{{local.mode}}",
                         "crash": "{{local.crash}}",
                         "laps":  "{{local.laps}}" } } }
      ] },

    { "type": "divider" },

    { "type": "state_text", "binding": "last_result",
      "default": "", "style": "body" },

    { "type": "row", "spacing": 12, "children": [
      { "type": "state_text", "binding": "lap",   "format": "Lap {}",   "style": "caption" },
      { "type": "state_text", "binding": "moves", "format": "Moves {}", "style": "caption" },
      { "type": "state_text", "binding": "speed", "format": "Speed {}", "style": "caption" }
    ] },
    { "type": "row", "spacing": 12, "children": [
      { "type": "state_text", "binding": "optimum", "format": "Optimum {}", "style": "caption" },
      { "type": "state_text", "binding": "best",    "format": "Best {}",    "style": "caption" },
      { "type": "state_text", "binding": "crashes", "format": "Crashes {}", "style": "caption" }
    ] },
    { "type": "row", "spacing": 12, "children": [
      { "type": "state_text", "binding": "mode",       "format": "Mode: {}",  "style": "caption" },
      { "type": "state_text", "binding": "crash_rule", "format": "Rule: {}",  "style": "caption" }
    ] }
  ]
}
