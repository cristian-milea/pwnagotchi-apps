{
  "type": "column",
  "padding": 16,
  "spacing": 12,
  "children": [
    { "type": "text", "value": "Weather", "style": "headline" },
    { "type": "state_text", "binding": "location",
      "default": "Set a location to begin", "style": "title" },
    { "type": "row", "spacing": 16, "children": [
      { "type": "state_text", "binding": "temp_c",
        "format": "{}°C", "default": "--", "style": "title" },
      { "type": "state_text", "binding": "condition",
        "default": "", "style": "body" }
    ]},
    { "type": "state_text", "binding": "feels_c",
      "format": "Feels like {}°C", "default": "", "style": "caption" },
    { "type": "state_text", "binding": "updated",
      "format": "Updated {}", "default": "", "style": "caption" },
    { "type": "divider" },
    { "type": "button", "label": "Sync now", "style": "primary",
      "action": { "type": "sync" } }
  ]
}
