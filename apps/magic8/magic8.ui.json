{
  "type": "column",
  "padding": 16,
  "spacing": 16,
  "children": [
    { "type": "text", "style": "body",
      "value": "Ask a yes-or-no question, then tap Shake. The answer appears on the e-ink." },
    { "type": "button", "label": "Shake", "style": "primary",
      "action": { "type": "push", "payload": { "action": "shake" } } },
    { "type": "state_text", "binding": "shake_count",
      "format": "Shaken {} times so far", "style": "caption" }
  ]
}
