{
  "type": "column",
  "padding": 16,
  "spacing": 12,
  "children": [
    { "type": "text", "value": "Magic 8-Ball", "style": "headline" },
    { "type": "state_text", "binding": "last_answer",
      "default": "Shake to ask…", "style": "title", "align": "center" },
    { "type": "button", "label": "Shake", "style": "primary",
      "action": { "type": "push", "payload": { "action": "shake" } } },
    { "type": "divider" },
    { "type": "row", "spacing": 8, "children": [
      { "type": "state_text", "binding": "shake_count",
        "format": "Shaken {} times", "style": "caption" },
      { "type": "spacer", "width": 8 },
      { "type": "state_text", "binding": "last_shake_at",
        "format": "Last: {}", "style": "caption" }
    ]}
  ]
}
