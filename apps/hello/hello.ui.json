{
  "type": "column",
  "padding": 16,
  "spacing": 12,
  "children": [
    { "type": "text", "value": "Hello, world", "style": "headline" },
    { "type": "text", "style": "body",
      "value": "Type something and tap Send. It'll appear on the pwnagotchi screen." },
    { "type": "text_field", "local": "msg", "label": "Message", "default": "" },
    { "type": "button", "label": "Send", "style": "primary",
      "action": {
        "type": "push",
        "payload": { "text": "{{local.msg}}" }
      }
    },
    { "type": "divider" },
    { "type": "text", "style": "caption",
      "value": "This is the example app — copy it as a starting point." }
  ]
}
